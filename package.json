{
  "name": "zepular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:styles": "ng build @zepular/styles",
    "build:overlay": "ng build @zepular/overlay",
    "build:message": "ng build @zepular/message",
    "build:menu": "ng build @zepular/menu",
    "build:panel": "ng build @zepular/panel",
    "build:form": "ng build @zepular/form",
    "build:button": "ng build @zepular/button",
    "build:file": "ng build @zepular/file",
    "build:data": "ng build @zepular/data",
    "build:all": "npm run build:styles && npm run build:overlay && npm run build:message && npm run build:menu && npm run build:panel && npm run build:form && npm run build:button && npm run build:file && npm run build:data",
    "prepublish:all": "npm run clean && npm run build:all",
    "publish:dry": "npm run prepublish:all && for d in styles overlay message menu panel form button file data; do echo \"--- @zepular/$d ---\"; npm publish dist/zepular/$d --access public --dry-run || exit 1; done",
    "publish:all": "npm run prepublish:all && for d in styles overlay message menu panel form button file data; do echo \"--- @zepular/$d ---\"; npm publish dist/zepular/$d --access public || exit 1; done",
    "whoami": "npm whoami --registry=https://registry.npmjs.org/",
    "clean": "rm -rf dist/",
    "storybook": "storybook dev -p 6006 -s public",
    "build-storybook": "storybook build -s public",
    "compodoc": "compodoc -p tsconfig.json -d documentation --theme default --disableCoverage --disablePrivate --disableInternal --disableProtected"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "storybook": "^10.3.5",
    "@storybook/angular": "^10.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1"
  }
}
