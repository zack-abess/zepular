      "prefix": "zep",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/zepular/overlay/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/zepular/overlay/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/zepular/overlay/tsconfig.spec.json"
          }
        }
      }
    },
    "@zepular/panel": {
      "projectType": "library",
      "root": "projects/zepular/panel",
      "sourceRoot": "projects/zepular/panel/src",
      "prefix": "zep",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/zepular/panel/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/zepular/panel/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
